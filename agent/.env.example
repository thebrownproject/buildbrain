# Convex connection
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:your-deploy-key-here

# Claude API (used by Pi SDK)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent config (optional)
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_THINKING=medium
VM_INSTANCE_ID=buildbrain-vm-1

# Paths (optional, defaults are relative to project root)
# CLI_TOOLS_DIR=/path/to/buildbrain/.claude/skills/cli-tools/scripts
# BUILDKIT_TOOLS_DIR=/path/to/buildkit/cli-tools
# TEMP_DIR=/tmp/buildbrain

# Health check (optional)
HEALTH_PORT=8080
